    <mxGraphModel dx="1018" dy="697" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" background="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="segments" parent="1" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeLast=0;collapsible=1;marginBottom=0;rounded=1;shadow=0;strokeColor=#000000;strokeWidth=2;" value="1. СЕГМЕНТЫ ПОТРЕБИТЕЛЕЙ" vertex="1">
          <mxGeometry height="180" width="260" x="40" y="40" as="geometry" />
        </mxCell>
        <mxCell id="segments_text" parent="segments" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingTop=4;wrap=1;" value="Ранние последователи:&#xa;• Занятые люди 25-45 лет&#xa;• Семьи с детьми&#xa;• Поклонники ЗОЖ&#xa;• Техно-гики / Владельцы умного дома" vertex="1">
          <mxGeometry height="150" width="260" y="30" as="geometry" />
        </mxCell>
        <mxCell id="problem" parent="1" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeLast=0;collapsible=1;marginBottom=0;rounded=1;shadow=0;strokeColor=#000000;strokeWidth=2;" value="2. ПРОБЛЕМА" vertex="1">
          <mxGeometry height="180" width="260" x="320" y="40" as="geometry" />
        </mxCell>
        <mxCell id="problem_text" parent="problem" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingTop=4;wrap=1;" value="1. Портящиеся продукты (забывают сроки)&#xa;2. Хаотичные покупки (лишнее/забытое)&#xa;3. Трудности с планированием меню&#xa;&#xa;СУЩЕСТВУЮЩИЕ АЛЬТЕРНАТИВЫ:&#xa;- Заметки в телефоне&#xa;- Трекеры с ручным вводом&#xa;- Готовые наборы еды" vertex="1">
          <mxGeometry height="150" width="260" y="30" as="geometry" />
        </mxCell>
        <mxCell id="uniqueValue" parent="1" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeLast=0;collapsible=1;marginBottom=0;rounded=1;shadow=0;strokeColor=#000000;strokeWidth=2;" value="3. УНИКАЛЬНАЯ ЦЕННОСТЬ" vertex="1">
          <mxGeometry height="180" width="280" x="600" y="40" as="geometry" />
        </mxCell>
        <mxCell id="unique_text" parent="uniqueValue" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingTop=4;wrap=1;" value="Ваш холодильник сам следит за сроками, &#xa;составляет меню и покупает продукты. &#xa;Вы просто наслаждаетесь едой без отходов.&#xa;&#xa;Ключевое отличие: Интеграция контроля &#xa;запасов с кулинарными рецептами и &#xa;списками покупок." vertex="1">
          <mxGeometry height="150" width="280" y="30" as="geometry" />
        </mxCell>
        <mxCell id="solution" parent="1" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeLast=0;collapsible=1;marginBottom=0;rounded=1;shadow=0;strokeColor=#000000;strokeWidth=2;" value="4. РЕШЕНИЕ" vertex="1">
          <mxGeometry height="180" width="260" x="40" y="240" as="geometry" />
        </mxCell>
        <mxCell id="solution_text" parent="solution" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingTop=4;wrap=1;" value="1. Приложение/сайт/тг-бот: сканирование &#xa;штрих-кода, база данных продуктов.&#xa;2. Уведомления: «Съешь сегодня», &#xa;«Испортится через 2 дня».&#xa;3. Авто-список покупок &#xa;(чего нет / скоро кончится).&#xa;4. Планировщик меню: &#xa;выбор блюда -&gt; добавление недостающего &#xa;в список." vertex="1">
          <mxGeometry height="150" width="260" y="30" as="geometry" />
        </mxCell>
        <mxCell id="channels" parent="1" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeLast=0;collapsible=1;marginBottom=0;rounded=1;shadow=0;strokeColor=#000000;strokeWidth=2;" value="5. КАНАЛЫ" vertex="1">
          <mxGeometry height="180" width="260" x="320" y="240" as="geometry" />
        </mxCell>
        <mxCell id="channels_text" parent="channels" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingTop=4;wrap=1;" value="Входящие:&#xa;- App Store / Google Play (ASO)&#xa;- Блоги, кулинарные сайты&#xa;&#xa;Исходящие:&#xa;- Таргетинг (Instagram, VK)&#xa;- Партнерства с магазинами&#xa;- YouTube-обзоры" vertex="1">
          <mxGeometry height="150" width="260" y="30" as="geometry" />
        </mxCell>
        <mxCell id="revenue" parent="1" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeLast=0;collapsible=1;marginBottom=0;rounded=1;shadow=0;strokeColor=#000000;strokeWidth=2;" value="6. ПОТОКИ ПРИБЫЛИ" vertex="1">
          <mxGeometry height="180" width="280" x="600" y="240" as="geometry" />
        </mxCell>
        <mxCell id="revenue_text" parent="revenue" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingTop=4;wrap=1;" value="• Freemium (база - бесплатно)&#xa;&#xa;• Premium подписка:&#xa;  - ИИ-планировщик меню (диеты)&#xa;  - Авто-загрузка по фото чека&#xa;  - Экспорт в корзину магазина&#xa;• Партнерские комиссии (доставка)" vertex="1">
          <mxGeometry height="150" width="280" y="30" as="geometry" />
        </mxCell>
        <mxCell id="costs" parent="1" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeLast=0;collapsible=1;marginBottom=0;rounded=1;shadow=0;strokeColor=#000000;strokeWidth=2;" value="7. СТРУКТУРА ИЗДЕРЖЕК" vertex="1">
          <mxGeometry height="180" width="260" x="40" y="440" as="geometry" />
        </mxCell>
        <mxCell id="costs_text" parent="costs" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingTop=4;wrap=1;" value="Постоянные:&#xa;- Команда разработки&#xa;- Серверы / облако&#xa;&#xa;Переменные:&#xa;- Маркетинг (реклама)&#xa;- API (базы штрих-кодов)" vertex="1">
          <mxGeometry height="150" width="260" y="30" as="geometry" />
        </mxCell>
        <mxCell id="metrics" parent="1" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeLast=0;collapsible=1;marginBottom=0;rounded=1;shadow=0;strokeColor=#000000;strokeWidth=2;" value="8. КЛЮЧЕВЫЕ МЕТРИКИ" vertex="1">
          <mxGeometry height="180" width="260" x="320" y="440" as="geometry" />
        </mxCell>
        <mxCell id="metrics_text" parent="metrics" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingTop=4;wrap=1;" value="• DAU / MAU, Retention&#xa;• Кол-во отсканированных продуктов&#xa;• % перехода на платную подписку&#xa;• Снижение % выбрасываемой еды (опросы)" vertex="1">
          <mxGeometry height="150" width="260" y="30" as="geometry" />
        </mxCell>
        <mxCell id="advantage" parent="1" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeLast=0;collapsible=1;marginBottom=0;rounded=1;shadow=0;strokeColor=#000000;strokeWidth=2;" value="9. СКРЫТОЕ ПРЕИМУЩЕСТВО" vertex="1">
          <mxGeometry height="180" width="280" x="600" y="440" as="geometry" />
        </mxCell>
        <mxCell id="advantage_text" parent="advantage" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingTop=4;wrap=1;" value="• Накопленная база данных реальных сроков&#xa; хранения.&#xa;&#xa;• Сетевой эффект: чем больше users, тем &#xa;точнее база.&#xa;&#xa;• Алгоритмы ИИ, предугадывающие привычки &#xa;питания." vertex="1">
          <mxGeometry height="150" width="280" y="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
